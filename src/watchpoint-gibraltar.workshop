rule("2.1: Player Joins")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Has Spawned(Event Player) == True;
	}

	actions
	{
		Event Player.isLoading = True;
		Wait(0.016, Ignore Condition);
		Disable Game Mode HUD(Event Player);
		Disable Game Mode In-World UI(Event Player);
		Disable Nameplates(Event Player, All Players(All Teams));
        Disable Movement Collision With Players(Event Player);
		Call Subroutine(loadLobby);
		Call Subroutine(loadNameplate);
		Wait(0.250, Ignore Condition);
		Event Player.isLoading = False;
	}
}

rule("2.1.1: Load Nameplate")
{
	event
	{
		Subroutine;
		loadNameplate;
	}

	actions
	{
		Destroy In-World Text(Event Player.nameplateObject);
		If(Event Player.isInLobby == True);
			Event Player.nameplate = Event Player;
		Else;
			If(Event Player.isInFreemode == False);
				Event Player.nameplate = Custom String("{0} | {1}", Event Player, Event Player.runCurrentCp);
			Else;
				Event Player.nameplate = Custom String("{0} | FREEMODE", Event Player);
			End;
		End;
		Create In-World Text(Filtered Array(All Players(All Teams), Current Array Element != Event Player), Event Player.nameplate,
			Event Player, 1, Clip Against Surfaces, Visible To Position and String, Color(White), Default Visibility);
		Event Player.nameplateObject = Last Text ID;
	}
}

rule("2.2: Player Leaves")
{
	event
	{
		Player Left Match;
		All;
		All;
	}

	actions
	{
		If(Event Player.runIsLoaded == True);
			Event Player.runIsPaused = True;
			Stop Chasing Player Variable(Event Player, runTime);
		End;
	}
}

rule("3.1.1: Load Lobby")
{
	event
	{
		Subroutine;
		loadLobby;
	}

	actions
	{
		Event Player.isInLobby = True;
		Teleport(Event Player, Global.lobbySpawn);
		Set Facing(Event Player, Direction Towards(Eye Position(Event Player), Vector(103.325, 0.600, 75.955)), To World);
		Event Player.isInFreemode = False;
		Event Player.lobbyText = Array();
		Event Player.lobbyEffects = Array();
		Event Player.lobbyIcons = Array();
	}
}

rule("3.1.1.1: Lobby Boundary")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.isInLobby == True;
		Event Player.isLoading == False;
		Distance Between(Position Of(Event Player), Global.lobbySpawn) > 13;
	}

	actions
	{
		Apply Impulse(Event Player, Direction Towards(Position Of(Event Player), Global.lobbySpawn), 10, To World, Cancel Contrary Motion);
	}
}

rule("3.2: Load Welcome Area")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.isInLobby == True;
	}

	actions
	{
		Create In-World Text(Event Player, Custom String("Welcome to Ballkour!"), Vector(103.325, 1.800, 75.955), 1.500, Do Not Clip, None,
			Color(Orange), Default Visibility);
		Event Player.lobbyText[0] = Last Text ID;
		Create In-World Text(Event Player, Custom String("ballkour.com"), Vector(103.325, 1.300, 75.955), 1, Do Not Clip, None,
			Custom Color(165, 42, 42, 255), Default Visibility);
		Event Player.lobbyText[1] = Last Text ID;
	}
}

