rule("3.4.1: Load Start Run Area")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.isInLobby == True;
	}

	actions
	{
		Create In-World Text(Event Player, Custom String("New Run"), Vector(103.805, -0.300, 75.480), 1, Do Not Clip, None, Color(
			Turquoise), Default Visibility);
		Event Player.lobbyText[13] = Last Text ID;
		Create Effect(Event Player, Ring, Color(Turquoise), Vector(103.805, -1.990, 75.480), 1.600, None);
		Event Player.lobbyEffects[0] = Last Created Entity;
		Create Icon(Event Player, Vector(103.805, -2.400, 75.480), Flag, None, Color(Green), True);
		Event Player.lobbyIcons[0] = Last Created Entity;
	}
}

rule("3.4.2: Start Run Circle Entry")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Distance Between(Position Of(Event Player), Vector(103.805, -1.990, 75.480)) < 2;
		Event Player.isInLobby == True;
		Event Player.isLoading == False;
	}

	actions
	{
		Event Player.isLoading = True;
		Call Subroutine(unloadLobby);
		Wait(0.016, Ignore Condition);
		Call Subroutine(newRun);
		Call Subroutine(loadRunHud);
		Call Subroutine(loadNameplate);
		Event Player.isLoading = False;
	}
}

rule("3.5.1: Load Resume Run Area")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.isInLobby == True;
		Event Player.runIsLoaded == True;
		Event Player.runIsFinished == False;
	}

	actions
	{
		Create In-World Text(Event Player, Custom String("Resume Run"), Vector(101.360, -0.300, 73.035), 1, Do Not Clip, None, Color(Blue),
			Default Visibility);
		Event Player.lobbyText[14] = Last Text ID;
		Create Effect(Event Player, Ring, Color(Blue), Vector(101.360, -1.990, 73.035), 1.600, None);
		Event Player.lobbyEffects[1] = Last Created Entity;
		Create Icon(Event Player, Vector(101.360, -2.400, 73.035), Recycle, None, Color(Purple), True);
		Event Player.lobbyIcons[1] = Last Created Entity;
	}
}

rule("3.5.2: Resume Run Circle Entry")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Distance Between(Position Of(Event Player), Vector(101.360, -1.990, 73.035)) < 2;
		Event Player.isInLobby == True;
		Event Player.runIsLoaded == True;
		Event Player.runIsFinished == False;
		Event Player.isLoading == False;
	}

	actions
	{
		Event Player.isLoading = True;
		Call Subroutine(unloadLobby);
		Wait(0.016, Ignore Condition);
		Call Subroutine(cpResetPlayer);
		Set Secondary Fire Enabled(Event Player, Event Player.cpData[4]);
		Call Subroutine(loadCpObjects);
		Call Subroutine(loadRunHud);
		Call Subroutine(loadNameplate);
		Event Player.isLoading = False;
	}
}

rule("3.6: Unload Lobby")
{
	event
	{
		Subroutine;
		unloadLobby;
	}

	actions
	{
		Event Player.isInLobby = False;
		For Player Variable(Event Player, index, 0, Count Of(Event Player.lobbyText), 1);
			Destroy In-World Text(Event Player.lobbyText[Event Player.index]);
		End;
		For Player Variable(Event Player, index, 0, Count Of(Event Player.lobbyEffects), 1);
			Destroy Effect(Event Player.lobbyEffects[Event Player.index]);
		End;
		For Player Variable(Event Player, index, 0, Count Of(Event Player.lobbyIcons), 1);
			Destroy Icon(Event Player.lobbyIcons[Event Player.index]);
		End;
		Allow Button(Event Player, Button(Crouch));
	}
}

rule("4: Load CP")
{
	event
	{
		Subroutine;
		loadCp;
	}

	actions
	{
		Call Subroutine(unloadCpObjects);
		Call Subroutine(loadCpData);
		If(Event Player.runCurrentCp <= 99);
			Call Subroutine(loadCpObjects);
		End;
		Call Subroutine(loadNameplate);
	}
}

rule("4.1: Load CP Data")
{
	event
	{
		Subroutine;
		loadCpData;
	}

	actions
	{
		"{0: Current CP; 1: Bounce Ring; 2: Bounce Used; 3: Next CP; 4: Grapple Allowed}"
		Event Player.cpData = Array();
		Event Player.cpData[0] = Global.cpLocations[Event Player.runCurrentCp];
		Event Player.cpData[1] = Global.cpBounceRings[Event Player.runCurrentCp];
		Event Player.cpData[2] = False;
		Event Player.cpData[3] = Global.cpLocations[Event Player.runCurrentCp + 1];
		Event Player.cpData[4] = Global.cpIsGrappleAllowed[Event Player.runCurrentCp];
		Set Secondary Fire Enabled(Event Player, Event Player.cpData[4]);
	}
}

rule("4.2.1: Load CP Objects")
{
	event
	{
		Subroutine;
		loadCpObjects;
	}

	actions
	{
		Event Player.cpEffects = Array();
		Event Player.cpIcons = Array();
		Create Effect(Event Player, Ring, Color(Green), Event Player.cpData[0], 2, Position and Radius);
		Event Player.cpEffects[0] = Last Created Entity;
		If(Event Player.cpData[1] != False);
			Create Effect(Event Player, Ring, Color(Orange), Event Player.cpData[1], 2, Position and Radius);
			Event Player.cpEffects[1] = Last Created Entity;
			Create Icon(Event Player, Event Player.cpData[1], Arrow: Up, Position, Color(Yellow), False);
			Event Player.cpIcons[0] = Last Created Entity;
		End;
		Create Effect(Event Player, Ring, Color(Sky Blue), Event Player.cpData[3], 2, Position and Radius);
		Event Player.cpEffects[2] = Last Created Entity;
		Create Icon(Event Player, Event Player.cpData[3] - Vector(0, 0.500, 0), Flag, Position, Color(Green), True);
		Event Player.cpIcons[1] = Last Created Entity;
		Create Effect(Event Player, Light Shaft, Color(Sky Blue), Event Player.cpData[3], 2, Position and Radius);
		Event Player.cpEffects[3] = Last Created Entity;
	}
}

rule("4.2.2: Unload CP Objects")
{
	event
	{
		Subroutine;
		unloadCpObjects;
	}

	actions
	{
		For Player Variable(Event Player, index, 0, Count Of(Event Player.cpEffects), 1);
			Destroy Effect(Event Player.cpEffects[Event Player.index]);
		End;
		For Player Variable(Event Player, index, 0, Count Of(Event Player.cpIcons), 1);
			Destroy Icon(Event Player.cpIcons[Event Player.index]);
		End;
	}
}

rule("5.1: Initialize New Run")
{
	event
	{
		Subroutine;
		newRun;
	}

	actions
	{
		Event Player.runIsLoaded = False;
		Event Player.runIsLoaded = True;
		Event Player.runIsPaused = True;
		Event Player.isInFreemode = False;
		Event Player.runIsFinished = False;
		Event Player.runCurrentCp = 0;
		Event Player.runTime = 0;
		Event Player.runTimeFormatted = Custom String("0.00");
		Event Player.runMistakes = 0;
		Call Subroutine(loadCp);
		Call Subroutine(cpResetPlayer);
	}
}

rule("5.2.1: Load Run HUD")
{
	event
	{
		Subroutine;
		loadRunHud;
	}

	actions
	{
		Event Player.runHud = Array();
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 0, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[0] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 1, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[1] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 2, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[2] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 3, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[3] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 4, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[4] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String("CTRLS: {0}", Input Binding String(Button(Ultimate))), Left, 4, Null, Null,
			Color(Orange), String, Default Visibility);
		Event Player.runHud[5] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String("ballkour.com"), Top, 0, Null, Null, Custom Color(165, 42, 42, 255), None,
			Default Visibility);
		Event Player.runHud[6] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String("{0}/100", Event Player.runCurrentCp), Top, 2, Null, Null, Color(Orange),
			String, Default Visibility);
		Event Player.runHud[7] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Right, 0, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[8] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Right, 1, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[9] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Right, 2, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[10] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Right, 3, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[11] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Right, 4, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[12] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String("{0} {1}", Icon String(Bolt), Event Player.runTimeFormatted), Right, 4,
			Null, Null, Color(Orange), String, Default Visibility);
		Event Player.runHud[13] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Right, 5, Null, Null, Color(White), None, Default Visibility);
		Event Player.runHud[14] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String("{0} {1}", Icon String(Skull), Event Player.runMistakes), Right, 6, Null,
			Null, Color(Orange), String, Default Visibility);
		Event Player.runHud[15] = Last Text ID;
	}
}

rule("5.2.2: Unload Run HUD")
{
	event
	{
		Subroutine;
		unloadRunHud;
	}

	actions
	{
		For Player Variable(Event Player, index, 0, Count Of(Event Player.runHud), 1);
			Destroy HUD Text(Event Player.runHud[Event Player.index]);
		End;
	}
}

rule("5.3: Update Timer")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.runIsPaused == False;
		Event Player.runIsLoaded == True;
	}

	actions
	{
		While(Event Player.runIsPaused == False);
			Call Subroutine(formatRunTime);
			Wait(0.030, Abort When False);
		End;
	}
}

rule("6: Start/Resume Run")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.runIsPaused == True;
		Distance Between(Position Of(Event Player), Event Player.cpData[0]) > 2.200;
		Event Player.isInFreemode == False;
		Has Status(Event Player, Rooted) == False;
		Event Player.isInLobby == False;
		Event Player.isLoading == False;
	}

	actions
	{
		Event Player.runIsPaused = False;
		Chase Player Variable At Rate(Event Player, runTime, 100000000, 1, Destination and Rate);
	}
}

rule("6.1: Grapple Use")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Secondary Fire)) == True;
	}

	actions
	{
		Set Ability Cooldown(Event Player, Button(Secondary Fire), 0);
	}
}

rule("6.2: Format Run Time String")
{
	event
	{
		Subroutine;
		formatRunTime;
	}

	actions
	{
		Event Player.hr = Round To Integer(Event Player.runTime / 3600, Down);
		Event Player.remainingSec = Event Player.runTime % 3600;
		Event Player.min = Round To Integer(Event Player.remainingSec / 60, Down);
		Event Player.sec = Round To Integer(Event Player.remainingSec % 60, Down);
		Event Player.hundredths = Round To Integer((Event Player.runTime - Round To Integer(Event Player.runTime, Down)) * 100, Down);
		If(Event Player.sec < 10);
			Event Player.secText = Custom String("0{0}", Event Player.sec);
		Else;
			Event Player.secText = Custom String("{0}", Event Player.sec);
		End;
		If(Event Player.hundredths < 10);
			Event Player.hundredthsText = Custom String("0{0}", Event Player.hundredths);
		Else;
			Event Player.hundredthsText = Custom String("{0}", Event Player.hundredths);
		End;
		If(Event Player.min < 10);
			Event Player.minText = Custom String("0{0}", Event Player.min);
		Else;
			Event Player.minText = Custom String("{0}", Event Player.min);
		End;
		If(Event Player.hr > 0);
			Event Player.runTimeFormatted = Custom String("{0}:{1}:{2}", Event Player.hr, Event Player.minText, Custom String("{0}.{1}",
				Event Player.secText, Event Player.hundredthsText));
		Else If(Event Player.min > 0);
			Event Player.runTimeFormatted = Custom String("{0}:{1}.{2}", Event Player.min, Event Player.secText, Event Player.hundredthsText);
		Else;
			Event Player.runTimeFormatted = Custom String("{0}.{1}", Event Player.sec, Event Player.hundredthsText);
		End;
	}
}

rule("7.1: CP Mistake")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Distance Between(Position Of(Event Player), Event Player.cpData[0]) > 2.200;
		(Event Player.cpData[1] == False || Event Player.cpData[2] == True) == True;
		Distance Between(Position Of(Event Player), Event Player.cpData[3]) > 2.200;
		Is On Ground(Event Player) == True;
		Event Player.runIsPaused == False;
		Event Player.isInFreemode == False;
		Has Status(Event Player, Rooted) == False;
		Event Player.isInLobby == False;
		Event Player.isLoading == False;
	}

	actions
	{
		Wait(0.050, Abort When False);
		Event Player.runMistakes += 1;
		Call Subroutine(cpResetPlayer);
	}
}

rule("7.2: Environment Death")
{
	event
	{
		Player Died;
		All;
		All;
	}

	actions
	{
		Event Player.isLoading = True;
		Respawn(Event Player);
		If(Event Player.isInFreemode == False);
			Event Player.runMistakes += 1;
		End;
		Call Subroutine(cpResetPlayer);
		Event Player.isLoading = False;
	}
}

rule("7.3.1: Bounce Ring CP Mistake: Too Slow")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.cpData[1] != False;
		Event Player.cpData[2] == False;
		Distance Between(Position Of(Event Player), Event Player.cpData[0]) > 2.200;
		Speed Of(Event Player) < 10;
		Is Button Held(Event Player, Button(Secondary Fire)) == False;
		Distance Between(Position Of(Event Player), Event Player.cpData[3]) > 2.200;
		Event Player.isInFreemode == False;
		Has Status(Event Player, Rooted) == False;
		Event Player.isLoading == False;
	}

	actions
	{
		Event Player.runMistakes += 1;
		Call Subroutine(cpResetPlayer);
	}
}

rule("7.3.2: Bounce CP Mistake: Improper Bounce")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.cpData[1] != False;
		Distance Between(Position Of(Event Player), Event Player.cpData[0]) > 2.200;
		Is Jumping(Event Player) == True;
		Event Player.isInFreemode == False;
		Has Status(Event Player, Rooted) == False;
		Event Player.isLoading == False;
	}

	actions
	{
		If(Distance Between(Position Of(Event Player), Event Player.cpData[1]) < 2.200);
			Event Player.cpData[2] = True;
		Else;
			Event Player.runMistakes += 1;
			Call Subroutine(cpResetPlayer);
		End;
	}
}

rule("8: CP Reset Player")
{
	event
	{
		Subroutine;
		cpResetPlayer;
	}

	actions
	{
		Event Player.isLoading = True;
		Set Status(Event Player, Null, Stunned, 0.016);
		Teleport(Event Player, Event Player.cpData[0]);
		Set Status(Event Player, Null, Rooted, 0.300);
		If(Event Player.runCurrentCp <= 99);
			Set Facing(Event Player, Direction Towards(Eye Position(Event Player), Global.cpLocations[Event Player.runCurrentCp + 1]),
				To World);
		End;
		Event Player.cpData[2] = False;
		Event Player.isLoading = False;
	}
}

rule("9: CP Completed (No Skipping)")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Distance Between(Position Of(Event Player), Event Player.cpData[3]) < 2.200;
		Is On Ground(Event Player) == True;
		Event Player.runIsLoaded == True;
		Event Player.runIsPaused == False;
		Event Player.isInFreemode == False;
		Has Status(Event Player, Rooted) == False;
		Event Player.isLoading == False;
	}

	actions
	{
		Event Player.runCurrentCp += 1;
		If(Event Player.runCurrentCp <= 99);
			Play Effect(Event Player, Ring Explosion Sound, Null, Event Player, 100);
		End;
		Call Subroutine(loadCp);
	}
}

rule("9.1: Final CP Reached")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.runCurrentCp == 100;
	}

	actions
	{
		Play Effect(Event Player, Bad Pickup Effect, Color(Lime Green), Event Player, 200);
		Play Effect(Event Player, Buff Impact Sound, Null, Event Player, 100);
		If(Event Player.runIsFinished == False);
			Call Subroutine(loadRunCompletionText);
			Event Player.runIsFinished = True;
		End;
		Event Player.isInFreemode = True;
		Set Secondary Fire Enabled(Event Player, True);
		If(Is Button Held(Event Player, Button(Ultimate)));
			Call Subroutine(unloadCtrlsHud);
			Call Subroutine(loadCtrlsHud);
		End;
		Call Subroutine(unloadFreemodeHud);
		Call Subroutine(loadFreemodeHud);
	}
}

rule("9.2: Final CP Completed (No Skipping)")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.runCurrentCp == 100;
		Event Player.runIsPaused == False;
	}

	actions
	{
		Event Player.runIsPaused = True;
		Stop Chasing Player Variable(Event Player, runTime);
	}
}

rule("9.3.1: Load Run Completion Text")
{
	event
	{
		Subroutine;
		loadRunCompletionText;
	}

	actions
	{
		Event Player.runCompletionText = Array();
		Create HUD Text(Event Player, Null, Custom String(" "), Null, Top, 2, Null, Color(White), Null, None, Default Visibility);
		Event Player.runCompletionText[0] = Last Text ID;
		Create HUD Text(Event Player, Null, Custom String(" "), Null, Top, 3, Null, Color(White), Null, None, Default Visibility);
		Event Player.runCompletionText[1] = Last Text ID;
		Create HUD Text(Event Player, Null, Custom String(" "), Null, Top, 4, Null, Color(White), Null, None, Default Visibility);
		Event Player.runCompletionText[2] = Last Text ID;
		Create HUD Text(Event Player, Null, Custom String("Congrats, {0}!", Event Player), Null, Top, 5, Null, Color(Yellow), Null, None,
			Default Visibility);
		Event Player.runCompletionText[3] = Last Text ID;
		Create HUD Text(Event Player, Null, Custom String(" "), Null, Top, 6, Null, Color(White), Null, None, Default Visibility);
		Event Player.runCompletionText[4] = Last Text ID;
		Create HUD Text(Event Player, Null, Custom String("Time: {0}", Event Player.runTimeFormatted), Null, Top, 7, Null, Color(Orange),
			Null, None, Default Visibility);
		Event Player.runCompletionText[5] = Last Text ID;
		Create HUD Text(Event Player, Null, Custom String("Mistakes: {0}", Event Player.runMistakes), Null, Top, 8, Null, Color(Orange),
			Null, None, Default Visibility);
		Event Player.runCompletionText[6] = Last Text ID;
		If(Event Player.runTime < Global.timeToBeatMs / 1000);
			Create HUD Text(Event Player, Null, Custom String(" "), Null, Top, 9, Null, Color(White), Null, None, Default Visibility);
			Event Player.runCompletionText[7] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("Top 10 time!"), Null, Top, 10, Null, Color(Orange), Null, None,
				Default Visibility);
			Event Player.runCompletionText[8] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("(Time to beat: {0})", Global.timeToBeat), Null, Top, 11, Null, Color(Orange),
				Null, None, Default Visibility);
			Event Player.runCompletionText[9] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("Submit a video of your run"), Null, Top, 12, Null, Custom Color(165, 42, 42,
				255), Null, None, Default Visibility);
			Event Player.runCompletionText[10] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("@"), Null, Top, 13, Null, Custom Color(165, 42, 42, 255), Null, None,
				Default Visibility);
			Event Player.runCompletionText[11] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("ballkour.com"), Null, Top, 14, Null, Custom Color(165, 42, 42, 255), Null, None,
				Default Visibility);
			Event Player.runCompletionText[12] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String(" "), Null, Top, 15, Null, Color(White), Null, None, Default Visibility);
			Event Player.runCompletionText[13] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("Thanks for playing!"), Null, Top, 16, Null, Color(Turquoise), Null, None,
				Default Visibility);
			Event Player.runCompletionText[14] = Last Text ID;
		End;
		Event Player.runCompletionTextActive = True;
	}
}

rule("9.3.2: Auto Unload Run Completion Text")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.runCompletionTextActive == True;
	}

	actions
	{
		Wait(30, Ignore Condition);
		Call Subroutine(unloadRunCompletionText);
		Event Player.runCompletionTextActive = False;
	}
}

rule("9.3.3.3: Unload Run Completion Text")
{
	event
	{
		Subroutine;
		unloadRunCompletionText;
	}

	actions
	{
		For Player Variable(Event Player, index, 0, Count Of(Event Player.runCompletionText), 1);
			Destroy HUD Text(Event Player.runCompletionText[Event Player.index]);
		End;
	}
}

rule("10.1.1: Controls HUD Input")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Event Player.isInLobby == False;
	}

	actions
	{
		Call Subroutine(loadCtrlsHud);
        Disallow Button(Event Player, Button(Primary Fire));
		Disallow Button(Event Player, Button(Secondary Fire));
        Disallow Button(Event Player, Button(Ability 2));
		Wait Until(Is Button Held(Event Player, Button(Ultimate)) == False || Event Player.isInLobby == True, 999999);
		Allow Button(Event Player, Button(Primary Fire));
		Allow Button(Event Player, Button(Secondary Fire));
        Allow Button(Event Player, Button(Ability 2));
	}
}

rule("10.1.2: Load Controls HUD")
{
	event
	{
		Subroutine;
		loadCtrlsHud;
	}

	actions
	{
		Event Player.ctrlsHud = Array();
		Create HUD Text(Event Player, Null, Custom String("Go Back:       {0} + {1}", Input Binding String(Button(Ultimate)),
			Input Binding String(Button(Primary Fire))), Null, Left, 5, Null, Color(Aqua), Null, String, Default Visibility);
		Event Player.ctrlsHud[1] = Last Text ID;
		If(Event Player.runCurrentCp <= 99);
			Create HUD Text(Event Player, Null, Custom String("Skip:                {0} + {1}", Input Binding String(Button(Ultimate)),
				Input Binding String(Button(Secondary Fire))), Null, Left, 6, Null, Color(Aqua), Null, String, Default Visibility);
			Event Player.ctrlsHud[2] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("Restart:           {0} + {1}", Input Binding String(Button(Ultimate)),
				Input Binding String(Button(Reload))), Null, Left, 7, Null, Color(Aqua), Null, String, Default Visibility);
			Event Player.ctrlsHud[3] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("Freemode:     {0} + {1}", Input Binding String(Button(Ultimate)),
				Input Binding String(Button(Interact))), Null, Left, 8, Null, Color(Aqua), Null, String, Default Visibility);
			Event Player.ctrlsHud[4] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("Lobby/Pause: {0} + {1}", Input Binding String(Button(Ultimate)),
				Input Binding String(Button(Ability 2))), Null, Left, 9, Null, Color(Aqua), Null, String, Default Visibility);
			Event Player.ctrlsHud[5] = Last Text ID;
		Else;
			Create HUD Text(Event Player, Null, Custom String("Restart:           {0} + {1}", Input Binding String(Button(Ultimate)),
				Input Binding String(Button(Reload))), Null, Left, 6, Null, Color(Aqua), Null, String, Default Visibility);
			Event Player.ctrlsHud[2] = Last Text ID;
			Create HUD Text(Event Player, Null, Custom String("Lobby:              {0} + {1}", Input Binding String(Button(Ultimate)),
				Input Binding String(Button(Ability 2))), Null, Left, 7, Null, Color(Aqua), Null, String, Default Visibility);
			Event Player.ctrlsHud[3] = Last Text ID;
		End;
		Event Player.ctrlsHudActive = True;
	}
}

rule("10.1.3: Auto Unload Controls HUD")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.ctrlsHudActive == True;
	}

	actions
	{
		Wait Until(!Is Button Held(Event Player, Button(Ultimate)) || Event Player.isInLobby, 9999999.000);
		Call Subroutine(unloadCtrlsHud);
		Event Player.ctrlsHudActive = False;
	}
}

rule("10.1.4: Unload Controls HUD")
{
	event
	{
		Subroutine;
		unloadCtrlsHud;
	}

	actions
	{
		For Player Variable(Event Player, index, 0, Count Of(Event Player.ctrlsHud), 1);
			Destroy HUD Text(Event Player.ctrlsHud[Event Player.index]);
		End;
	}
}

rule("10.2: Go Back CP Input")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Is Button Held(Event Player, Button(Primary Fire)) == True;
		Event Player.runCurrentCp >= 1;
		Event Player.isInLobby == False;
		Event Player.cpCtrlsInputLocked == False;
		Event Player.isLoading == False;
	}

	actions
	{
		Event Player.cpCtrlsInputLocked = True;
        Event Player.isLoading = True;
		If(Event Player.runIsPaused == False);
			Stop Chasing Player Variable(Event Player, runTime);
			Event Player.runIsPaused = True;
			If(Distance Between(Position Of(Event Player), Event Player.cpData[0]) > 2.200);
				Event Player.runMistakes += 1;
			End;
		End;
		Event Player.runCurrentCp -= 1;
		If(Event Player.runCurrentCp == 99);
			Call Subroutine(unloadFreemodeHud);
			Call Subroutine(loadFreemodeHud);
			Call Subroutine(unloadCtrlsHud);
			Call Subroutine(loadCtrlsHud);
		End;
		Call Subroutine(loadCp);
		Call Subroutine(cpResetPlayer);
		Wait Until(Is Button Held(Event Player, Button(Ultimate)) == False || Is Button Held(Event Player, Button(Primary Fire)) == False, 0.150);
		While(Is Button Held(Event Player, Button(Ultimate)) && Is Button Held(Event Player, Button(Primary Fire)) && Event Player.runCurrentCp >= 1);
			Event Player.runCurrentCp -= 1;
			Call Subroutine(loadCp);
			Call Subroutine(cpResetPlayer);
			Wait(0.02, Ignore Condition);
		End;
        Wait Until(Is Button Held(Event Player, Button(Primary Fire)) == False || Is Button Held(Event Player, Button(Ultimate)) == False, 999999);
        Event Player.cpCtrlsInputLocked = False;
        Event Player.isLoading = False;
	}
}

rule("10.3: Skip CP Input")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Is Button Held(Event Player, Button(Secondary Fire)) == True;
		Event Player.runCurrentCp <= 99;
		Event Player.isInLobby == False;
        Event Player.cpCtrlsInputLocked == False;
		Event Player.isLoading == False;
	}

	actions
	{
		Event Player.isLoading = True;
        Event Player.cpCtrlsInputLocked = True;
		If(Event Player.runIsPaused == False);
			Stop Chasing Player Variable(Event Player, runTime);
			Event Player.runIsPaused = True;
			If(Distance Between(Position Of(Event Player), Event Player.cpData[0]) > 2.200);
				Event Player.runMistakes += 1;
			End;
		End;
		Event Player.runCurrentCp += 1;
		Call Subroutine(loadCp);
		Call Subroutine(cpResetPlayer);
		Wait Until(Is Button Held(Event Player, Button(Ultimate)) == False || Is Button Held(Event Player, Button(Secondary Fire)) == False, 0.150);
		While(Is Button Held(Event Player, Button(Ultimate)) && Is Button Held(Event Player, Button(Secondary Fire)) && Event Player.runCurrentCp <= 99);
			Event Player.runCurrentCp += 1;
			Call Subroutine(loadCp);
			Call Subroutine(cpResetPlayer);
			Wait(0.020, Ignore Condition);
		End;
        Wait Until(Is Button Held(Event Player, Button(Secondary Fire)) == False || Is Button Held(Event Player, Button(Ultimate)) == False, 999999);
        Event Player.cpCtrlsInputLocked = False;
        Event Player.isLoading = False;
	}
}

rule("10.4: Restart Input")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Is Button Held(Event Player, Button(Reload)) == True;
		Event Player.isInLobby == False;
	}

	actions
	{
		Event Player.isLoading = True;
		Stop Chasing Player Variable(Event Player, runTime);
		Call Subroutine(unloadFreemodeHud);
		Call Subroutine(unloadRunCompletionText);
		Call Subroutine(newRun);
		Event Player.isLoading = False;
	}
}

rule("10.5: Freemode Input")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Is Button Held(Event Player, Button(Interact)) == True;
		Event Player.isInLobby == False;
		Event Player.runCurrentCp <= 99;
	}

	actions
	{
		If(Event Player.isInFreemode == False);
			Stop Chasing Player Variable(Event Player, runTime);
			Event Player.runIsPaused = True;
			If(Distance Between(Position Of(Event Player), Event Player.cpData[0]) > 2.200);
				Event Player.runMistakes += 1;
			End;
			Set Secondary Fire Enabled(Event Player, True);
			Event Player.isInFreemode = True;
			Call Subroutine(unloadFreemodeHud);
			Call Subroutine(loadFreemodeHud);
		Else;
			Event Player.isInFreemode = False;
			Call Subroutine(unloadFreemodeHud);
			If(Distance Between(Position Of(Event Player), Event Player.cpData[0]) > 2.200);
				Call Subroutine(cpResetPlayer);
			End;
		End;
	}
}

rule("10.5.1: Load Freemode HUD")
{
	event
	{
		Subroutine;
		loadFreemodeHud;
	}

	actions
	{
		Event Player.freemodeHud = Array();
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 10, Null, Null, Color(White), None, Default Visibility);
		Event Player.freemodeHud[0] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 11, Null, Null, Color(White), None, Default Visibility);
		Event Player.freemodeHud[1] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 12, Null, Null, Color(White), None, Default Visibility);
		Event Player.freemodeHud[2] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 13, Null, Null, Color(White), None, Default Visibility);
		Event Player.freemodeHud[3] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 14, Null, Null, Color(White), None, Default Visibility);
		Event Player.freemodeHud[4] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String(" "), Left, 15, Null, Null, Color(White), None, Default Visibility);
		Event Player.freemodeHud[5] = Last Text ID;
		Create HUD Text(Event Player, Null, Null, Custom String("Freemode On"), Left, 16, Null, Null, Color(Orange), None,
			Default Visibility);
		Event Player.freemodeHud[6] = Last Text ID;
		If(Event Player.runCurrentCp <= 99);
			Create HUD Text(Event Player, Null, Null, Custom String("Disable: {0} + {1}", Input Binding String(Button(Ultimate)),
				Input Binding String(Button(Interact))), Left, 17, Null, Null, Custom Color(165, 42, 42, 255), String, Default Visibility);
			Event Player.freemodeHud[7] = Last Text ID;
		Else;
			Create HUD Text(Event Player, Null, Null, Custom String("Restart: {0} + {1}", Input Binding String(Button(Ultimate)),
				Input Binding String(Button(Reload))), Left, 17, Null, Null, Custom Color(165, 42, 42, 255), String, Default Visibility);
			Event Player.freemodeHud[7] = Last Text ID;
		End;
	}
}

rule("10.5.2: Unload Freemode HUD")
{
	event
	{
		Subroutine;
		unloadFreemodeHud;
	}

	actions
	{
		For Player Variable(Event Player, index, 0, Count Of(Event Player.freemodeHud), 1);
			Destroy HUD Text(Event Player.freemodeHud[Event Player.index]);
		End;
	}
}

rule("10.6: Lobby Input")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Is Button Held(Event Player, Button(Ability 2)) == True;
		Event Player.isInLobby == False;
	}

	actions
	{
		Event Player.isLoading = True;
		If(Event Player.runIsPaused == False);
			Stop Chasing Player Variable(Event Player, runTime);
			Event Player.runMistakes += 1;
			Event Player.runIsPaused = True;
		End;
		Call Subroutine(unloadCpObjects);
		Call Subroutine(unloadRunHud);
		Call Subroutine(unloadFreemodeHud);
		Call Subroutine(unloadRunCompletionText);
		Call Subroutine(loadLobby);
		Event Player.isLoading = False;
	}
}