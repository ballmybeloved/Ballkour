settings
{
	main
	{
		Description: "Ball Parkour"
		Mode Name: "Ballkour"
	}

	lobby
	{
		Allow Players Who Are In Queue: Yes
		Map Rotation: Paused
		Match Voice Chat: Enabled
		Max Spectators: 12
		Max Team 1 Players: 12
		Max Team 2 Players: 0
		Return To Lobby: Never
		Swap Teams After Match: No
	}

	modes
	{
		Skirmish
		{
			enabled maps
			{
				Watchpoint: Gibraltar 972777519512099996
			}
		}

		General
		{
			Hero Limit: Off
		}
	}

	heroes
	{
		General
		{
			Wrecking Ball
			{
				Grappling Claw Cooldown Time: 0%
				No Ammunition Requirement: On
				Piledriver Cooldown Time: 0%
				Ultimate Generation - Passive Minefield: 0%
			}

			enabled heroes
			{
				Wrecking Ball
			}
		}
	}
}

variables
{
	global:
		0: timeToBeat
		1: timeToBeatMs
		2: lobbySpawn
		3: cpLocations
		4: cpBounceRings
		5: cpIsGrappleAllowed

	player:
		0: isLoading
		1: isInLobby
		2: lobbyText
		3: lobbyEffects
		4: lobbyIcons
		5: nameplate
		6: nameplateObject
		7: runIsLoaded
        8: runHud
		9: runCurrentCp
		10: runMistakes
		11: runTime
		12: runTimeFormatted
		13: hr
		14: remainingSec
		15: min
		16: minText
		17: sec
		18: secText
		19: hundredths
		20: hundredthsText
		21: cpData
		22: cpEffects
		23: cpIcons
        24: runIsPaused
		25: runIsFinished
        26: isInFreemode
		27: freemodeHud
		28: runCompletionText
		29: runCompletionTextActive
		30: ctrlsHud
		31: ctrlsHudActive
        32: cpCtrlsInputLocked
		100: index
}

subroutines
{
	0: loadLobby
	1: loadNameplate
	2: unloadLobby
	3: loadCp
	4: newRun
	5: loadRunHud
    6: formatRunTime
	7: loadCpData
	8: loadCpObjects
	9: cpResetPlayer
	10: unloadCpObjects
	11: unloadRunHud
	12: loadFreemodeHud
	13: unloadFreemodeHud
	14: loadRunCompletionText
	15: unloadRunCompletionText
    16: loadCtrlsHud
	17: unloadCtrlsHud
}

rule("0: Contact & Course Info")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Log To Inspector(Custom String("Hello! Welcome to Ballkour's Watchpoint: Gibraltar course!"));
		Log To Inspector(Custom String(
			"This updated version of code \"DQGPG\" is developed by ballmybeloved, with lobby help from Kalaziel64."));
		Log To Inspector(Custom String(
			"This route was slightly adjusted for quality purposes, and also because this map was updated in Feb, 2026."));
		Log To Inspector(Custom String(
			"Any comments, questions, or issues? Want to join our Discord or beat the time to beat? Visit ballkour.com!"));
		Log To Inspector(Custom String("Course run: ballkour.com/playthrough"));
		Global.timeToBeat = Custom String("5:19.05");
		Global.timeToBeatMs = 319050;
	}
}

rule("1.1: Initialize Match")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Disable Inspector Recording;
		Disable Built-In Game Mode Announcer;
		Disable Built-In Game Mode Completion;
		Set Match Time(0);
	}
}

